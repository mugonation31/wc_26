rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Picks: anyone can read (leaderboard), only the owner can write their own doc.
    // A client can never downgrade eliminated from true → false (only the Cloud Function can set it).
    match /picks/{userId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && !(resource != null
             && resource.data.eliminated == true
             && request.resource.data.eliminated == false);
    }

  }
}
